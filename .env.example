# Copy to .env.local — never commit real secrets

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server: Postgres pooler (bắt buộc cho API kho — không dùng mock client)
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres

# Session-mode pooler (migrations / DDL)
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# Transaction-mode pooler (app queries)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

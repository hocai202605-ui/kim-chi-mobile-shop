# Copy to .env.local — never commit real secrets

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Transaction-mode pooler (APP runtime — port 6543). Avoids EMAXCONNSESSION.
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session-mode pooler (migrations / DDL only — port 5432). Do NOT use for app queries.
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# Optional: node-pg max connections per process (default 3)
# PG_POOL_MAX=3
